# Line-ending policy (DEFERRED-040).
#
# Normalize every text file to LF in the repo AND the working tree. `eol=lf`
# overrides each machine's `core.autocrlf` (true on Windows), so checkouts no
# longer smudge files to CRLF. CRLF in the working tree is what silently broke
# heading-aware chunking (`^#{1,3}\s+(.+)$` doesn't match `\r`-terminated lines)
# and what spews "LF will be replaced by CRLF" warnings on every commit.
# The chunker is now CRLF-robust (normalizeNewlines), but this kills the source.
* text=auto eol=lf

# Append-only audit log — union-merge so concurrent appends never conflict
# (this was the only prior rule; preserved).
docs/audit/AUDIT_LOG.jsonl merge=union

# Explicit binaries — never touch line endings (belt-and-suspenders over text=auto's
# auto-detection so a mis-detected binary can't be corrupted by LF normalization).
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.webp  binary
*.ico   binary
*.pdf   binary
*.zip   binary
*.woff  binary
*.woff2 binary
