DATABASE_URL=postgresql://contexthub:contexthub@127.0.0.1:5432/contexthub
EMBEDDINGS_BASE_URL=http://127.0.0.1:1234
#EMBEDDINGS_API_KEY=
# Model string used in your curl example:
EMBEDDINGS_MODEL=mixedbread-ai/text-embedding-mxbai-embed-large-v1

# When false (default), MCP tool calls do NOT require `workspace_token`.
# Set true to restore the previous “token required” behavior.
MCP_AUTH_ENABLED=false
CONTEXT_HUB_WORKSPACE_TOKEN=change-me

# MVP defaults:
EMBEDDINGS_DIM=1024
CHUNK_LINES=120
# Indexing / generated-docs / manifest / QA–RAPTOR budgets (optional; defaults = previous hardcoded values).
# INDEX_MAX_FILE_BYTES=2000000
# INDEX_EMBEDDING_BATCH_SIZE=8
# GENERATED_INDEX_MAX_DOCS=5000
# MANIFEST_MAX_FILE_BYTES=2000000
# MANIFEST_LINE_READ_MAX_BYTES=512000
# BUILDER_MEMORY_SAMPLE_MAX_FILES=64
# BUILDER_MEMORY_SAMPLE_MAX_FILE_CHARS=6000
# BUILDER_MEMORY_SAMPLE_MAX_TOTAL_CHARS=90000
# DISTILLATION_COMPRESS_MIN_OUTPUT_CHARS=200
# DISTILLATION_COMPRESS_MAX_OUTPUT_CHARS=32000
# RAPTOR_L1_SUMMARY_MIN_CHARS=1800
# RAPTOR_L1_SUMMARY_MAX_CHARS=14000
# RAPTOR_L2_SUMMARY_MIN_CHARS=2000
# RAPTOR_L2_SUMMARY_MAX_CHARS=16000
# QA_SUMMARY_SCALED_MIN_CHARS=1200
# QA_SUMMARY_SCALED_MAX_CHARS=8000
# QA_SUMMARY_HARD_MAX_CHARS=16000
# QA_SUMMARY_OUTPUT_MIN_CHARS=200
# QA_EVIDENCE_SCALED_MIN_CHARS=2200
# QA_EVIDENCE_SCALED_MAX_CHARS=8000
# QA_EVIDENCE_ANSWER_HARD_MAX_CHARS=12000
# QA_EVIDENCE_OUTPUT_MIN_CHARS=300
# LLM_SUMMARY_SOURCE_CHAR_CEILING=2000000
# RETRIEVAL_SNIPPET_MAX_CHARS=400
# RERANK_LLM_MAX_TOKENS=250
MCP_PORT=3000

# When set, MCP tools may omit project_id (and add_lesson may omit lesson_payload.project_id).
# Use one id per repo or per team; it is not configured via Cursor mcp.json for HTTP transport.
# DEFAULT_PROJECT_ID=my-workspace

# Phase 3 (optional): OpenAI-compatible chat for distillation / reflect / compress.
# When false (default), behavior matches Phase 2 for lesson writes (no chat calls).
DISTILLATION_ENABLED=false
# Required when DISTILLATION_ENABLED=true:
# DISTILLATION_MODEL=qwen2.5-coder:7b
# Optional overrides (defaults to EMBEDDINGS_*):
# DISTILLATION_BASE_URL=http://127.0.0.1:1234
# DISTILLATION_API_KEY=

# Optional dedicated rerank endpoint/model (used by search_code filters.rerank_mode=llm).
# Falls back to DISTILLATION_* (then EMBEDDINGS_*) if not set.
# RERANK_BASE_URL=http://127.0.0.1:1234
# RERANK_API_KEY=
# RERANK_MODEL=qwen2.5-7b-instruct
# RERANK_TIMEOUT_MS=1800

# Optional dedicated QA agent endpoint/model for faq.build and raptor.build synthesis.
# Falls back to DISTILLATION_* if not set.
# QA_AGENT_BASE_URL=http://127.0.0.1:1234
# QA_AGENT_API_KEY=
# QA_AGENT_MODEL=qwen2.5-7b-instruct
# QA_AGENT_TIMEOUT_MS=12000
# FAQ/RAPTOR: head+tail excerpt if input exceeds this; dynamic max_tokens capped below.
# QA_SUMMARIZE_MAX_INPUT_CHARS=120000
# LLM_COMPLETION_MAX_TOKENS_CAP=4096

# Optional dedicated Phase 6+ multi-agent models.
# Useful when Builder / QC / Judge run on different models/providers.
# All are optional and can fallback to DISTILLATION_* in callers.
# BUILDER_AGENT_BASE_URL=http://127.0.0.1:1234
# BUILDER_AGENT_API_KEY=
# BUILDER_AGENT_MODEL=qwen2.5-coder:7b
# BUILDER_AGENT_TIMEOUT_MS=12000
# QC_AGENT_BASE_URL=http://127.0.0.1:1234
# QC_AGENT_API_KEY=
# QC_AGENT_MODEL=qwen2.5-7b-instruct
# QC_AGENT_TIMEOUT_MS=12000
# JUDGE_AGENT_BASE_URL=http://127.0.0.1:1234
# JUDGE_AGENT_API_KEY=
# JUDGE_AGENT_MODEL=qwen2.5-7b-instruct
# JUDGE_AGENT_TIMEOUT_MS=12000

# Phase 4 (optional): Neo4j-backed knowledge graph.
# When false (default), graph ingest/query tools return graceful warnings.
KG_ENABLED=false
NEO4J_URI=bolt://127.0.0.1:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=neo4jpassword

# Phase 5 (optional): Git intelligence automation.
# When false (default), git ingestion and analysis tools return graceful warnings.
GIT_INGEST_ENABLED=false
GIT_MAX_COMMITS_PER_RUN=200

# Async queue worker / RabbitMQ.
QUEUE_ENABLED=false
QUEUE_BACKEND=postgres
JOB_QUEUE_NAME=default
RABBITMQ_URL=amqp://guest:guest@127.0.0.1:5672
RABBITMQ_EXCHANGE=contexthub.jobs

# Source mode defaults.
REPO_CACHE_ROOT=/data/repos
SOURCE_STORAGE_MODE=local
WORKSPACE_SCAN_ENABLED=false

# S3-compatible storage (required when SOURCE_STORAGE_MODE=s3|hybrid).
S3_ENDPOINT=http://127.0.0.1:9000
S3_REGION=us-east-1
S3_BUCKET=contexthub-artifacts
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_FORCE_PATH_STYLE=true

# Knowledge loop + quality eval (opt-in). Jobs knowledge.loop.* no-op unless KNOWLEDGE_LOOP_ENABLED=true.
# Deprecated aliases still work: PHASE6_KNOWLEDGE_LOOP_ENABLED → KNOWLEDGE_LOOP_ENABLED (see migrateLegacyEnvKeys in src/env.ts).
KNOWLEDGE_LOOP_ENABLED=false
# Golden-set path for worker `quality.eval`.
QUALITY_EVAL_QUERIES_PATH=qc/queries.json
# Optional gates (0 = disabled). Baseline doc_key when using set_baseline on quality.eval.
QUALITY_EVAL_MIN_RECALL_AT3=0
QUALITY_EVAL_MIN_RECALL_DELTA=0
QUALITY_EVAL_MAX_P95_MS=0
QUALITY_EVAL_NO_REGRESS_GROUPS=
QUALITY_EVAL_KG_ASSIST=false
QUALITY_EVAL_BASELINE_DOC_KEY=quality_eval/baseline
# Builder memory in deep loop (BUILDER_AGENT_* or DISTILLATION_*).
BUILDER_MEMORY_ENABLED=true
# Large-repo hierarchical memory: auto when estimated LOC >= threshold. 0 = LOC auto off (use payload.large_repo only).
BUILDER_MEMORY_LARGE_REPO_LOC_THRESHOLD=5000000
# Optional caps for knowledge.memory.build / deep large-repo path.
MEMORY_BUILD_MAX_SHARDS=500

# npm run verify:phase6:qc (optional overrides; not read by getEnv)
# QC_VERIFY_REPO_ROOT=/workspace
# QC_VERIFY_PROJECT_ID=phase6-qc-free-context-hub
# QC_VERIFY_CORRELATION_ID=
# QC_VERIFY_DEEP_MAX_ROUNDS=3
# QC_VERIFY_SKIP_BUILDER_MEMORY=false
# Smoke: SMOKE_KNOWLEDGE_LOOP=true (deprecated: SMOKE_PHASE6)
