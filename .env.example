DATABASE_URL=postgresql://contexthub:contexthub@127.0.0.1:5432/contexthub
EMBEDDINGS_BASE_URL=http://127.0.0.1:1234
# Model string used in your curl example:
EMBEDDINGS_MODEL=mixedbread-ai/text-embedding-mxbai-embed-large-v1

# When false (default), MCP tool calls do NOT require `workspace_token`.
# Set true to restore the previous “token required” behavior.
MCP_AUTH_ENABLED=false
CONTEXT_HUB_WORKSPACE_TOKEN=change-me

# MVP defaults:
EMBEDDINGS_DIM=1024
CHUNK_LINES=120
MCP_PORT=3000

# When set, MCP tools may omit project_id (and add_lesson may omit lesson_payload.project_id).
# Use one id per repo or per team; it is not configured via Cursor mcp.json for HTTP transport.
# DEFAULT_PROJECT_ID=my-workspace

# Phase 3 (optional): OpenAI-compatible chat for distillation / reflect / compress.
# When false (default), behavior matches Phase 2 for lesson writes (no chat calls).
DISTILLATION_ENABLED=false
# Required when DISTILLATION_ENABLED=true:
# DISTILLATION_MODEL=qwen2.5-coder:7b
# Optional overrides (defaults to EMBEDDINGS_*):
# DISTILLATION_BASE_URL=http://127.0.0.1:1234
# DISTILLATION_API_KEY=

# Phase 4 (optional): Neo4j-backed knowledge graph.
# When false (default), graph ingest/query tools return graceful warnings.
KG_ENABLED=false
NEO4J_URI=bolt://127.0.0.1:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=neo4jpassword

# Phase 5 (optional): Git intelligence automation.
# When false (default), git ingestion and analysis tools return graceful warnings.
GIT_INGEST_ENABLED=false
GIT_MAX_COMMITS_PER_RUN=200

# Async queue worker / RabbitMQ (Phase 6 prep).
QUEUE_ENABLED=false
QUEUE_BACKEND=postgres
JOB_QUEUE_NAME=default
RABBITMQ_URL=amqp://guest:guest@127.0.0.1:5672
RABBITMQ_EXCHANGE=contexthub.jobs

# Source mode defaults.
REPO_CACHE_ROOT=/data/repos
WORKSPACE_SCAN_ENABLED=false

