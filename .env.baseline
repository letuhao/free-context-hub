# Phase 17.x — Controlled-state baseline environment.
#
# When running `qc:baseline:gen`, load these vars (e.g.
# `docker compose --env-file .env --env-file .env.baseline up -d ...`)
# so every LLM caller in the stack points at the SAME chat model and
# embeddings model. This prevents LM Studio's auto-unload from
# swapping models mid-baseline (which causes "Channel Error" failures
# and ECONNRESET cascades).
#
# Invariant: exactly TWO models must be loaded in LM Studio:
#   1. mistralai/mistral-nemo-instruct-2407    (chat, all roles)
#   2. text-embedding-bge-m3                   (embeddings)
#
# Verify before each baseline run via scripts/preflight-baseline.sh.

# ─── Chat / answerer / judge / reranker — ONE model, ALL roles ───
# Same-model bias acknowledged (~3-5pp inflation per published reports);
# the gain in measurement stability outweighs this for first baselines.
ANSWERER_AGENT_MODEL=mistralai/mistral-nemo-instruct-2407
JUDGE_AGENT_MODEL=mistralai/mistral-nemo-instruct-2407
RERANK_MODEL=mistralai/mistral-nemo-instruct-2407
# 2026-06-16: runtime default RERANK_TYPE is now 'api' (cross-encoder via
# local-rerank-service). Baselines must pin the LEGACY generative reranker so
# the controlled LLM-only measurement is unaffected by the new default. The
# cross-encoder is measured separately as its own tagged benchmark config.
RERANK_TYPE=generative

# Builder + QA agents — disabled or pinned to same chat model.
BUILDER_AGENT_MODEL=mistralai/mistral-nemo-instruct-2407
QA_AGENT_MODEL=mistralai/mistral-nemo-instruct-2407

# ─── Distillation worker — DISABLED during baseline ───
# The distillation worker would otherwise hit LM Studio with granite-4
# in the background, triggering swaps. Empty model = worker no-ops.
#
# 2026-06-17 belt-and-suspenders: DISTILLATION_ENABLED=false ALSO required.
# Without this gate the worker's `generateSearchAliases` / `qaAgent` /
# `builderMemory` paths still try to call LM Studio with the chain
# `QA_AGENT_MODEL ?? DISTILLATION_MODEL ?? null`, and if either falls
# through to a non-empty value it triggers a mid-baseline swap. The
# previous baselines (incl. v9 reference) were RUN with worker active
# and DISTILLATION_MODEL=gemma leaking from .env — model variance was
# masquerading as template-related delta. See
# docs/qc/2026-06-17-baseline-stack-bug-postmortem.md.
DISTILLATION_MODEL=
DISTILLATION_ENABLED=false

# ─── Embeddings ───
EMBEDDINGS_MODEL=text-embedding-bge-m3

# ─── Endpoints (no change vs .env; documented for clarity) ───
# All LLM calls go through host.docker.internal:1234 from inside Docker.
# Local-host runs (npx tsx ...) hit localhost:1234 directly.
JUDGE_AGENT_BASE_URL=http://host.docker.internal:1234/v1
ANSWERER_AGENT_BASE_URL=http://host.docker.internal:1234/v1
EMBEDDINGS_BASE_URL=http://host.docker.internal:1234

# Reasonable timeouts given mistral-nemo's response speed.
JUDGE_AGENT_TIMEOUT_MS=120000
ANSWERER_AGENT_TIMEOUT_MS=60000
RAGAS_JUDGE_TIMEOUT_MS=180000
