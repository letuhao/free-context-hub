{
  "name": "free-context-hub",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "type": "module",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "worker": "tsx src/worker.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "migrate": "tsx src/db/migrate.ts",
    "test": "tsx --test src/services/gitCommitFileParse.test.ts src/services/gitLessonProposalUpsert.test.ts src/services/exchange/base64Stream.test.ts src/services/exchange/bundleFormat.test.ts src/services/pinnedHttpAgent.test.ts src/services/exchange/pullFromRemote.test.ts src/services/lessons.test.ts src/services/documentChunks.test.ts src/services/salience.test.ts src/services/artifactLeases.test.ts src/services/sweepScheduler.test.ts src/api/routes/me.test.ts src/api/middleware/requireScope.test.ts src/qc/metrics.test.ts src/qc/diffBaselines.test.ts src/qc/noiseFloor.test.ts",
    "test:integration": "tsx src/qc/integrationTestRunner.ts",
    "smoke-test": "tsx src/smoke/smokeTest.ts",
    "test:e2e:smoke": "tsx test/e2e/smoke/runner.ts",
    "test:e2e:api": "tsx test/e2e/api/runner.ts",
    "test:e2e:gui": "npx playwright test --config=test/e2e/gui/playwright.config.ts",
    "test:e2e:agent": "tsx test/e2e/agent/runner.ts",
    "test:e2e": "npm run test:e2e:smoke && npm run test:e2e:api && npm run test:e2e:gui && npm run test:e2e:agent",
    "bench:phase5": "tsx src/smoke/phase5ValidationBenchmark.ts",
    "validate:phase5-worker": "tsx src/smoke/phase5WorkerValidation.ts",
    "qc:rag": "tsx src/qc/ragQcRunner.ts",
    "qc:baseline": "tsx src/qc/runBaseline.ts",
    "qc:baseline:diff": "tsx src/qc/diffBaselines.ts",
    "qc:goldenset:validate": "node scripts/validate-goldenset.mjs",
    "test:metrics": "tsx --test src/qc/metrics.test.ts",
    "verify:phase6": "tsx src/scripts/verifyPhase6.ts",
    "verify:phase6:prereq": "tsx src/scripts/phase6PrereqCheck.ts",
    "verify:phase6:prereq:compose": "docker compose exec -T -w /app mcp npm run verify:phase6:prereq",
    "verify:phase6:qc": "tsx src/scripts/verifyPhase6Qc.ts",
    "verify:phase6:qc:compose": "docker compose exec -T -w /app mcp env QC_VERIFY_REPO_ROOT=/workspace npm run verify:phase6:qc",
    "verify:phase6:qc:builder-memory": "tsx src/scripts/verifyPhase6QcBuilderMemory.ts",
    "verify:phase6:qc:builder-memory:compose": "docker compose exec -T -w /app mcp env QC_VERIFY_REPO_ROOT=/workspace npm run verify:phase6:qc:builder-memory",
    "enqueue:knowledge.memory.build": "tsx src/scripts/enqueueKnowledgeMemoryBuild.ts",
    "enqueue:knowledge.memory.build:compose": "docker compose exec -T -w /app mcp env QC_VERIFY_REPO_ROOT=/workspace npm run enqueue:knowledge.memory.build",
    "seed:qc-worst15-lessons": "tsx src/scripts/seedQcWorst15Lessons.ts",
    "verify:phase6:audit": "tsx src/scripts/phase6AuditCorrelation.ts",
    "verify:phase6:lesson-probe": "tsx src/scripts/phase6LessonProbe.ts",
    "qc:rag:phase6": "tsx src/scripts/qcRagPhase6.ts",
    "backfill:generated-docs": "tsx src/scripts/backfillGeneratedDocs.ts",
    "ci:mock-embeddings": "node scripts/ci-mock-embeddings.mjs",
    "distill-probe": "tsx src/smoke/distillProbe.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/letuhao/free-context-hub.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/letuhao/free-context-hub/issues"
  },
  "homepage": "https://github.com/letuhao/free-context-hub#readme",
  "dependencies": {
    "@ai-sdk/openai-compatible": "^2.0.37",
    "@aws-sdk/client-s3": "^3.1018.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@types/amqplib": "^0.10.8",
    "@types/multer": "^2.1.0",
    "@types/turndown": "^5.0.6",
    "ai": "^6.0.141",
    "amqplib": "^0.10.9",
    "archiver": "^7.0.1",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "fast-glob": "^3.3.3",
    "mammoth": "^1.12.0",
    "multer": "^2.1.1",
    "neo4j-driver": "^6.0.1",
    "pdf-parse": "^2.4.5",
    "pg": "^8.20.0",
    "pg-cursor": "^2.19.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "redis": "^5.11.0",
    "ts-morph": "^27.0.2",
    "turndown": "^7.2.4",
    "undici": "^6.21.2",
    "uuid": "^13.0.0",
    "yauzl": "^3.3.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/archiver": "^7.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "@types/pg": "^8.20.0",
    "@types/pg-cursor": "^2.7.2",
    "@types/yauzl": "^2.10.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
